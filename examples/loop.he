
multiply (i32 a, i32 b) -> i32 {
    -> a * b
}

add_thirty (i32 num) -> i32 {
    // 1..10 evaluates to an iterator
    // This pattern can be used with any iterator
    for i in 1..10 {
        num = num + 1 // 10
    }
    
    :: max = 20
    for i in 1..max {
        num = num + 1 // 30
    }
    -> num
}

main () {
    :: res = add_thirty(50)
    printf(res) // 80
}

